// This is your Prisma schema file
// Banco: SQLite (zero instalação no Windows!)
// Para trocar para PostgreSQL depois: mude provider e DATABASE_URL no .env

generator client {
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  provider      = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite não suporta enum — usamos String com valores fixos por convenção:
// role: "CLIENTE" | "RESTAURANTE" | "ADMIN"
// status: "AGUARDANDO" | "EM_PREPARO" | "PRONTO" | "RETIRADO"

model Usuario {
  id            Int                 @id @default(autoincrement())
  nome          String
  email         String              @unique
  senha         String
  cpf           String?             @unique
  telefone      String?
  role          String              @default("CLIENTE")
  ativo         Boolean             @default(true)
  criadoEm      DateTime            @default(now())
  pedidos       Pedido[]
  restauranteId Int?
  restaurante   Restaurante?        @relation(fields: [restauranteId], references: [id])
  notificacoes  NotificacoesConfig?
}

model Restaurante {
  id        Int       @id @default(autoincrement())
  nome      String
  descricao String?
  logo      String?
  aberto    Boolean   @default(true)
  ativo     Boolean   @default(true)
  itens     Item[]
  pedidos   Pedido[]
  usuarios  Usuario[]
}

model Categoria {
  id    Int    @id @default(autoincrement())
  nome  String @unique
  itens Item[]
}

model Item {
  id             Int          @id @default(autoincrement())
  nome           String
  descricao      String?
  preco          Float
  disponivel     Boolean      @default(true)
  imagemFilename String?
  restauranteId  Int
  categoriaId    Int?
  restaurante    Restaurante  @relation(fields: [restauranteId], references: [id])
  categoria      Categoria?   @relation(fields: [categoriaId], references: [id])
  itensPedido    ItemPedido[]
}

model Pedido {
  id            Int          @id @default(autoincrement())
  status        String       @default("AGUARDANDO")
  total         Float
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt
  clienteId     Int
  restauranteId Int
  cliente       Usuario      @relation(fields: [clienteId], references: [id])
  restaurante   Restaurante  @relation(fields: [restauranteId], references: [id])
  itens         ItemPedido[]
}

model ItemPedido {
  id         Int    @id @default(autoincrement())
  quantidade Int
  precoUnit  Float
  pedidoId   Int
  itemId     Int
  pedido     Pedido @relation(fields: [pedidoId], references: [id])
  item       Item   @relation(fields: [itemId], references: [id])
}

model NotificacoesConfig {
  id              Int     @id @default(autoincrement())
  usuarioId       Int     @unique
  novosPedidos    Boolean @default(true)
  notifEmail      Boolean @default(false)
  notifPlataforma Boolean @default(true)
  usuario         Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}
