// This is your Prisma schema file
// Banco: SQLite (zero instalação no Windows!)
// Para trocar para PostgreSQL depois: mude provider e DATABASE_URL no .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENTE
  RESTAURANTE
  ADMIN
}

enum StatusPedido {
  AGUARDANDO
  EM_PREPARO
  PRONTO
  RETIRADO
}

model Usuario {
  id            Int          @id @default(autoincrement())
  nome          String
  email         String       @unique
  senha         String
  cpf           String?      @unique
  telefone      String?
  role          Role         @default(CLIENTE)
  ativo         Boolean      @default(true)
  criadoEm      DateTime     @default(now())
  pedidos       Pedido[]
  restauranteId Int?
  restaurante   Restaurante? @relation(fields: [restauranteId], references: [id])
}

model Restaurante {
  id        Int       @id @default(autoincrement())
  nome      String
  descricao String?
  logo      String?
  aberto    Boolean   @default(true)
  ativo     Boolean   @default(true)
  itens     Item[]
  pedidos   Pedido[]
  usuarios  Usuario[]
}

model Categoria {
  id    Int    @id @default(autoincrement())
  nome  String
  itens Item[]
}

model Item {
  id            Int          @id @default(autoincrement())
  nome          String
  descricao     String?
  preco         Float
  disponivel    Boolean      @default(true)
  restauranteId Int
  categoriaId   Int?
  restaurante   Restaurante  @relation(fields: [restauranteId], references: [id])
  categoria     Categoria?   @relation(fields: [categoriaId], references: [id])
  itensPedido   ItemPedido[]
}

model Pedido {
  id            Int          @id @default(autoincrement())
  status        StatusPedido @default(AGUARDANDO)
  total         Float
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt
  clienteId     Int
  restauranteId Int
  cliente       Usuario      @relation(fields: [clienteId], references: [id])
  restaurante   Restaurante  @relation(fields: [restauranteId], references: [id])
  itens         ItemPedido[]
}

model ItemPedido {
  id         Int    @id @default(autoincrement())
  quantidade Int
  precoUnit  Float
  pedidoId   Int
  itemId     Int
  pedido     Pedido @relation(fields: [pedidoId], references: [id])
  item       Item   @relation(fields: [itemId], references: [id])
}
